# AQI & Traffic Dashboard Configuration

# Register at https://aqicn.org/api/ to get your token
WAQI_API_KEY=YOUR_WAQI_TOKEN_HERE

# Register at https://developer.tomtom.com/ to get your key
TOMTOM_API_KEY=YOUR_TOMTOM_KEY_HERE

# Database configuration (defaults to SQLite)
# DATABASE_URL=postgresql://aqi_user:aqi_password@localhost:5432/aqi_db

# City to track (Default: Indore)
DEFAULT_CITY=Indore
